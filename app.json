{
  "expo": {
    "name": "Chainrails Playground",
    "slug": "chainrailsplayground",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "chainrailsplayground",
    "userInterfaceStyle": "automatic",
    "ios": {
          "icon": "./assets/expo.icon",
          "bundleIdentifier": "com.chainrails.playground",
          "buildNumber": "1"
        },
    "android": {
          "package": "com.chainrails.playground",
          "versionCode": 1,
          "newArchEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#BBEDE9",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0B0B",
          "dark": {
            "backgroundColor": "#0B0B0B"
          },
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "265622ff-02c2-412c-8956-c20b28114720"
      }
    },
    "owner": "goodyboys-team"
  }
}
